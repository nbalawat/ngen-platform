{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngen.io/schemas/mcpserver.schema.json",
  "title": "NGEN MCPServer CRD",
  "description": "Schema for MCPServer custom resource definitions in the NGEN multi-agent platform",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "enum": ["ngen.io/v1", "ngen.io/v1beta1", "ngen.io/v1alpha1"]
    },
    "kind": {
      "type": "string",
      "const": "MCPServer"
    },
    "metadata": { "$ref": "agent.schema.json#/$defs/metadata" },
    "spec": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string", "enum": ["openapi", "database", "custom"] },
            "url": { "type": "string" },
            "schemaRef": { "type": "string" },
            "config": { "type": "object" }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["oauth2", "api-key", "none"] },
            "secretRef": { "type": "string" },
            "config": { "type": "object" }
          }
        },
        "scaling": { "$ref": "agent.schema.json#/$defs/scaling" },
        "transport": { "type": "string", "default": "streamable-http" },
        "healthCheckPath": { "type": "string", "default": "/health" }
      }
    }
  }
}
